# ──────────────────────────────────────────────
# Firebase (frontend)
# ──────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=https://SEU_PROJETO-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ──────────────────────────────────────────────
# Backend — Vercel API Routes
# ──────────────────────────────────────────────
# Firebase Admin SDK service account JSON (string completa)
# Obtido em: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# URL do Realtime Database (mesma do VITE_FIREBASE_DATABASE_URL, sem VITE_)
FIREBASE_DATABASE_URL=https://SEU_PROJETO-default-rtdb.firebaseio.com

# URL do frontend (para CORS) — deixe * em desenvolvimento
FRONTEND_URL=https://seu-projeto.vercel.app

# ──────────────────────────────────────────────
# Emuladores locais (opcional)
# ──────────────────────────────────────────────
VITE_USE_EMULATORS=false
